# Environment Variables — Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas > Your Cluster > Connect > Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/finance-tracker?retryWrites=true&w=majority

# Secret key used to sign JWT tokens — use any long random string
JWT_SECRET=your_super_secret_key_here_change_this

# Port for the server (optional, defaults to 5000)
PORT=5000

# Your Vercel frontend URL (set this on Render after deploying)
CLIENT_URL=https://your-app.vercel.app
